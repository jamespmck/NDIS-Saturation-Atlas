scripts/
tools/

# Do not commit raw or intermediate data
data/raw/
data/processed/

# Keep curated published CSV outputs, but ignore bulky/generated variants
data/published/.gitkeep
data/published/*backup*
data/published/*BEFORE*
data/published/*.xlsx
data/published/*.parquet
data/published/master_ndis_service_area_latest.csv
data/published/master_ndis_service_area_quarter_2024_present.csv
data/published/national_benchmark_quarter_2024_present.csv
data/published/master_ndis_service_area_quarter_service_type.csv
